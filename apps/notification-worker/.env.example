# Redis
# Local: redis://localhost:6379
# Railway: use ${{ Redis.REDIS_URL }} reference in Railway Variables
REDIS_URL=redis://localhost:6379

# Brevo (Email)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM_NAME=TuAgenda
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Meta WhatsApp Cloud API
# Get these from: https://developers.facebook.com/apps/ > WhatsApp > API Setup
META_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Note: Brevo template IDs and Meta template names are configured per business
# in the database (Business.notificationSettings), not here.
