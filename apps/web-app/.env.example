# Redis (Notifications Queue)
# Local: redis://localhost:6379
# Vercel: use the public URL from Railway Redis service
REDIS_URL=redis://localhost:6379

# Database
# For local development
DATABASE_URL="postgresql://usuario:password@localhost:5432/tuagenda"
# For Vercel deployment, use POSTGRES_PRISMA_URL (automatically set by Vercel Postgres)

# Firebase Configuration (Client Side)
# Get these values from your Firebase Console:
# https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (Server Side)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate Private Key
# https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Analytics
# Get your Measurement ID from Google Analytics 4
# https://analytics.google.com/ > Admin > Data Streams > Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Support WhatsApp
# Phone number in international format without + or spaces (e.g. 5491122334455)
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER=

# Waitlist Google Form URL
NEXT_PUBLIC_WAITLIST_FORM_URL=

# Tawk.to Live Chat
# Get these values from your Tawk.to dashboard
# https://dashboard.tawk.to/ > Administration > Channels > Chat Widget
# Format: https://embed.tawk.to/{PROPERTY_ID}/{WIDGET_ID}
NEXT_PUBLIC_TAWK_PROPERTY_ID=69b90cb38509b31c30dd2423
NEXT_PUBLIC_TAWK_WIDGET_ID=1jjtdj7aa
